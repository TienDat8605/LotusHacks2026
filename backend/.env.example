PORT=8080
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# OpenRouteService (optional; improves geocoding/routing)
ORS_API_KEY=

# VietMap fallback geocoding for Vietnam (optional)
VIETMAP_API_KEY=

# AI assistant
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional: docker secret-style key file path
# OPENAI_API_KEY_FILE=/run/secrets/openai_api_key

# Optional Zilliz vector search (assistant can still run without these)
ZILLIZ_URI=
ZILLIZ_TOKEN=
ZILLIZ_DB_NAME=

# Defaults to ../data/pois.json if empty
# Defaults to ../data/data.json if empty
POI_DATA_PATH=../data/data.json
