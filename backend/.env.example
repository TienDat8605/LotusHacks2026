PORT=8080
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# OpenRouteService (optional; improves geocoding/routing)
ORS_API_KEY=

# VietMap fallback geocoding for Vietnam (optional)
VIETMAP_API_KEY=

# Defaults to ../data/pois.json if empty
# Defaults to ../data/data.json if empty
POI_DATA_PATH=../data/data.json

# Review assistant / RAG (optional)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
REVIEW_DATA_PATH=../data/data.json
REVIEW_EMBEDDING_CACHE_PATH=../data/review-embeddings-cache.json
